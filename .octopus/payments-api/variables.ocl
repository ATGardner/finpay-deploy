variable "Project.Helm.Namespace" {
    value "fraud-dev" {
        environment = ["development"]
    }

    value "fraud-staging" {
        environment = ["staging"]
    }

    value "fraud-prod" {
        environment = ["production"]
    }
}

variable "Project.Helm.Values" {
    value "values-#{Octopus.Environment.Name | ToLower}.yaml" {}
}

variable "something" {
    value "blah blah" {}
}